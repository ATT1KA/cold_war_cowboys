@using System.Linq
@using Sandbox
@using Sandbox.UI
@using CWC.Narrative
@using CWC.UI
@inherits Panel
@namespace CWC.UI

<root class="scenereader priority-@PriorityClass tone-@ToneClass">
	@if ( Vm?.CurrentScene is { } scene )
	{
		<div class="scene-frame">
			<div class="scene-head">
				<div class="scene-title">@scene.Title</div>
				<div class="scene-setting">@scene.Setting</div>
			</div>

			<div class="scene-body">
				@if ( !string.IsNullOrEmpty( scene.Speaker ) )
				{
					<div class="speaker">@scene.Speaker</div>
				}
				@foreach ( var line in scene.TextLines )
				{
					<div class="line">@line</div>
				}
			</div>

			<div class="choices">
				@if ( scene.Choices.Count == 0 )
				{
					<button class="choice-button" @onclick=@OnDismiss>Continue →</button>
				}
				else
				{
					@{
						// Night 8: at corruption >= 80, cold choices surface first.
						// "Cold" = negative conscience delta OR flagged with "choice:cold"
						// or "choice:transactional". This makes ruthless options feel natural.
						var orderedChoices = Vm?.ShouldInvertChoices == true
							? scene.Choices.OrderByDescending( c =>
								( c.ConscienceDelta < 0 ? 2 : 0 )
								+ ( c.FlagsOnPick.Any( f => f.Contains( "cold" ) || f.Contains( "transactional" )
									|| f.Contains( "machine" ) || f.Contains( "weapon" ) ) ? 1 : 0 )
							).ToList()
							: scene.Choices;
					}
					@foreach ( var c in orderedChoices )
					{
						<button class="choice-button" @onclick=@(() => OnPick(c))>@c.Label</button>
					}
				}
			</div>
		</div>
	}
	else
	{
		<div class="scene-empty">No pending scenes.</div>
	}
</root>

@code
{
	[Property] public IGameViewModel? Vm { get; set; }

	private string PriorityClass => Vm?.CurrentScene?.Priority.ToString().ToLowerInvariant() ?? "none";

	// Night 8: tone modifier CSS class for dialogue rendering
	private string ToneClass => Vm?.CurrentScene?.Tone.ToString().ToLowerInvariant() ?? "normal";

	private void OnPick( SceneChoice c ) => Vm?.PickChoice( c );
	private void OnDismiss() => Vm?.DismissScene();

	protected override int BuildHash() => System.HashCode.Combine(
		Vm?.CurrentScene?.TemplateId, Vm?.CurrentScene?.OperativeId,
		Vm?.CurrentScene?.Priority, Vm?.CurrentScene?.Tone
	);
}
