<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>CWC.PolicySim</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Compiles the REAL game code — this simulator cannot drift from the
         resolver the way the old python mirror (balance_test.py) did. -->
    <Compile Include="..\..\code\Core\**\*.cs" />
    <Compile Include="..\..\code\Domain\**\*.cs" />
    <Compile Include="..\..\code\Game\**\*.cs" />
    <Compile Include="..\..\code\Generation\**\*.cs" />
    <Compile Include="..\..\code\Missions\**\*.cs" />
    <Compile Include="..\..\code\Narrative\**\*.cs" />
    <Compile Include="..\..\code\Corporate\**\*.cs" />
    <Compile Include="..\..\code\Save\**\*.cs" />
    <Compile Include="..\..\tests\SmokeTest\DiskFileProvider.cs" />
  </ItemGroup>
</Project>
